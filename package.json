{
  "name": "@anhnguyen02/catlas",
  "version": "1.0.5",
  "description": "Graph-powered code intelligence for AI agents.",
  "files": [
    "dist",
    "README.md"
  ],
  "main": "index.js",
  "type": "module",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "scripts": {
    "test": "vitest run",
    "build": "tsc && npm run obfuscate",
    "obfuscate": "javascript-obfuscator dist --output dist --compact true --self-defending false --string-array-encoding rc4 --string-array-rotate true --string-array-shuffle true --string-array-threshold 0.75",
    "dev": "tsx watch src/cli/index.ts",
    "prepare": "husky"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai-agents",
    "code-intelligence",
    "code-analysis",
    "knowledge-graph",
    "code-search",
    "static-analysis",
    "dependency-graph",
    "tree-sitter",
    "refactoring",
    "developer-tools",
    "codex",
    "cursor",
    "claude"
  ],
  "author": "anhnv02",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anhnv02/catlas.git"
  },
  "bugs": {
    "url": "https://github.com/anhnv02/catlas/issues"
  },
  "homepage": "https://github.com/anhnv02/catlas#readme",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "catlas": "dist/cli/index.js"
  },
  "overrides": {
    "sharp": "npm:is-buffer@^2.0.5",
    "@huggingface/transformers": {
      "onnxruntime-node": "$onnxruntime-node"
    }
  },
  "dependencies": {
    "@huggingface/transformers": "^3.0.0",
    "@ladybugdb/core": "^0.15.2",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "cli-progress": "^3.12.0",
    "commander": "^12.0.0",
    "glob": "^11.0.0",
    "graphology": "^0.25.4",
    "graphology-indices": "^0.17.0",
    "graphology-utils": "^2.3.0",
    "ignore": "^7.0.5",
    "lru-cache": "^11.0.0",
    "mnemonist": "^0.39.0",
    "onnxruntime-node": "^1.24.0",
    "pandemonium": "^2.4.0",
    "path-scurry": "^2.0.2",
    "tree-sitter": "^0.21.1",
    "tree-sitter-c": "0.23.2",
    "tree-sitter-c-sharp": "^0.23.1",
    "tree-sitter-cpp": "^0.23.4",
    "tree-sitter-go": "0.23.0",
    "tree-sitter-java": "^0.23.5",
    "tree-sitter-javascript": "^0.23.0",
    "tree-sitter-php": "^0.23.0",
    "tree-sitter-python": "0.23.4",
    "tree-sitter-ruby": "^0.23.1",
    "tree-sitter-rust": "0.23.1",
    "tree-sitter-typescript": "^0.23.2",
    "uuid": "^13.0.0"
  },
  "optionalDependencies": {
    "tree-sitter-dart": "github:UserNobody14/tree-sitter-dart#80e23c07b64494f7e21090bb3450223ef0b192f4",
    "tree-sitter-kotlin": "^0.3.8",
    "tree-sitter-swift": "^0.6.0"
  },
  "devDependencies": {
    "@types/cli-progress": "^3.11.6",
    "@types/node": "^20.0.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "javascript-obfuscator": "^5.4.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.4.5",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{ts,js,json,md}": [
      "prettier --write"
    ]
  }
}
